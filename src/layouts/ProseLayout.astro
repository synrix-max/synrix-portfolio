---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string | Date;
  description?: string;
  collection?: string;   // "blog" | "journal" | "notes"
}

const { title, date, description, collection } = Astro.props;

const backMap: Record<string, string> = {
  blog:    '/blog',
  journal: '/journal',
  notes:   '/notes',
};
const back = collection ? backMap[collection] ?? '/' : '/';

function fmtDate(d: string | Date) {
  return new Date(d).toLocaleDateString('en-GB', {
    day: '2-digit', month: 'short', year: 'numeric'
  });
}
---

<BaseLayout title={title} description={description}>
  <article class="prose-wrap">
    <header class="prose-header">
      <a href={back} class="back-link">← back</a>
      <h1 class="prose-title">{title}</h1>
      <time class="prose-date">{fmtDate(date)}</time>
    </header>

    <div class="prose-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .prose-wrap { max-width: 640px; }

  .back-link {
    display: inline-block;
    font-size: 12px;
    color: var(--text-dim);
    border-bottom: none;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: var(--text); border-bottom: none; }

  .prose-header { margin-bottom: 2rem; }

  .prose-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-hi);
    line-height: 1.3;
    margin-bottom: 0.4rem;
  }

  .prose-date {
    font-size: 11px;
    color: var(--text-dim);
  }

  /* prose body typography */
  .prose-body { font-size: 13px; color: var(--text); line-height: 1.85; }

  .prose-body h2 {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-hi);
    margin: 2rem 0 0.6rem;
  }
  .prose-body h3 {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin: 1.5rem 0 0.4rem;
  }

  .prose-body p  { margin-bottom: 1rem; }
  .prose-body ul,
  .prose-body ol { margin: 0.5rem 0 1rem 1.2rem; }
  .prose-body li { margin-bottom: 0.25rem; }

  .prose-body a  { color: var(--accent); border-bottom: 1px solid #3a3020; }
  .prose-body a:hover { border-color: var(--accent); }

  .prose-body code {
    font-family: var(--font);
    font-size: 12px;
    color: var(--accent);
    background: #161006;
    border: 1px solid #2a1e00;
    padding: 1px 5px;
    border-radius: 2px;
  }

  .prose-body pre {
    background: #111;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 12px;
    line-height: 1.6;
  }
  .prose-body pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
  }

  .prose-body blockquote {
    border-left: 2px solid #2a2a2a;
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1rem 0;
  }

  .prose-body hr {
    border: none;
    border-top: 1px solid var(--border-sub);
    margin: 1.5rem 0;
  }
</style>
