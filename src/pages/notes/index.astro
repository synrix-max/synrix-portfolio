---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="notes">
  <div class="section-title">notes</div>

  <div class="notes-list">
    {notes.map((n) => (
      <div class="note-row">
        <a href={`/notes/${n.slug}`} class="note-link">{n.data.title}</a>
        {n.data.tags && (
          <div class="note-tags">
            {n.data.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .notes-list { display: flex; flex-direction: column; }

  .note-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.35rem 0;
    border-bottom: 1px solid #111;
    gap: 1rem;
  }
  .note-row:last-child { border-bottom: none; }

  .note-link {
    font-size: 13px;
    color: var(--text-mid);
    border-bottom: none;
  }
  .note-link:hover { color: var(--text); }

  .note-tags { display: flex; gap: 0.4rem; flex-shrink: 0; }
</style>
